# ── PickGen environment ─────────────────────────────────────────────
# Copy to backend/.env for local dev. Everything has safe dev defaults;
# the whole app runs with NO real keys (mock AI + mock payments).

# ── Server ──
PORT=8787
NODE_ENV=development
# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173

# ── Auth ──
# Secret for signing session JWTs. Change in production.
JWT_SECRET=dev-secret-change-me

# ── Database ──
# SQLite file path (relative to backend/) — used only when DATABASE_URL is empty.
DB_PATH=./data/pickgen.db
# Set to a Postgres connection string (e.g. Neon) to use Postgres instead of SQLite.
# postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# ── AI provider ──
# provider: "mock" (default, no key) | "fal"
AI_PROVIDER=mock
# fal.ai key — only needed when AI_PROVIDER=fal (format: key_id:key_secret)
FAL_KEY=
# Optional: override fal.ai model endpoints per mode (defaults shown)
# FAL_MODEL_DRAFT=fal-ai/flux/schnell
# FAL_MODEL_QUALITY=fal-ai/flux-pro/v1.1
# FAL_MODEL_TEXT=fal-ai/ideogram/v2
# Optional: OpenAI-compatible key for prompt translation/enhancement.
# When empty, a built-in heuristic enhancer is used (no network).
OPENAI_API_KEY=

# ── Payments ──
# provider: "mock" (dev) | "nowpayments" | "cryptomus" | "lemonsqueezy"
PAYMENT_PROVIDER=mock
# Public URL of THIS backend (Render) — needed for payment callbacks/webhooks.
# e.g. https://pickgen-backend-sqru.onrender.com
PUBLIC_API_URL=
# NOWPayments (crypto, USDT payout) — only when PAYMENT_PROVIDER=nowpayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Cryptomus (crypto + card) — only when PAYMENT_PROVIDER=cryptomus
CRYPTOMUS_MERCHANT=
CRYPTOMUS_API_KEY=
# Lemon Squeezy — only when PAYMENT_PROVIDER=lemonsqueezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ── Limits ──
# Free trial credits granted to a brand-new user (0 = only the free daily draft)
FREE_SIGNUP_CREDITS=0
# Free-tier draft generations per day (applies after FREE_TIER_START)
FREE_DAILY_DRAFTS=1
# Paid-only launch window: no free drafts before this ISO date. Empty = free tier active now.
FREE_TIER_START=2026-08-12
# Rate limit: max generation requests per minute per user
RATE_LIMIT_PER_MIN=12
